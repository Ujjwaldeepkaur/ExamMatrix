<!DOCTYPE html>
<html>
<head>
    <title>Assignments</title>

    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: Arial;
            background: linear-gradient(to right, #667eea, #764ba2);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            width: 850px;
            background: white;
            padding: 40px;
            border-radius: 20px;
            text-align: center;
            box-shadow: 0px 0px 20px rgba(0,0,0,0.2);
        }

        .box {
            background: #f4f6f7;
            padding: 20px;
            margin: 20px 0;
            border-radius: 12px;
            text-align: left;
        }

        h1 {
            color: #2c3e50;
        }

        h2 {
            color: #34495e;
        }

        p {
            color: #555;
            font-size: 16px;
        }

        a {
            text-decoration: none;
            background: #3498db;
            color: white;
            padding: 10px 18px;
            border-radius: 8px;
            display: inline-block;
            margin-top: 10px;
        }

        a:hover {
            background: #2980b9;
        }

        .back {
            background: #27ae60;
            margin-top: 25px;
        }
    </style>
</head>

<body>

<div class="container">

    <h1>Uploaded Assignments</h1>

    <% if(assignments.length === 0) { %>

        <h2>No assignments uploaded yet</h2>

    <% } else { %>

        <% assignments.forEach(function(assignment) { %>

            <div class="box">
                <h2><%= assignment.title %></h2>
                <p><b>Subject:</b> <%= assignment.subject %></p>
                <p><b>Description:</b> <%= assignment.description %></p>

                <a href="/uploads/<%= assignment.fileUrl %>" target="_blank">
                    Open Uploaded File
                </a>
            </div>

        <% }) %>

    <% } %>

    <a href="/teacher-dashboard" class="back">Back to Dashboard</a>

</div>

</body>
</html>