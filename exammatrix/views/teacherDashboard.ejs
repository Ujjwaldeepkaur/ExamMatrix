<!DOCTYPE html>
<html>
<head>
    <title>Teacher Dashboard</title>

    <style>

        body {
            margin: 0;
            padding: 0;
            font-family: Arial;
            background: #fff3e0;
            text-align: center;
        }

        .container {
            width: 850px;
            margin: 50px auto;
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0px 0px 20px rgba(0,0,0,0.2);
        }

        h1 {
            color: #2c3e50;
        }

        h2 {
            color: #34495e;
            margin-top: 30px;
        }

        a {
            text-decoration: none;
            background: #3498db;
            color: white;
            padding: 12px 24px;
            border-radius: 8px;
            display: inline-block;
            margin: 10px;
            font-size: 16px;
        }

        a:hover {
            background: #2980b9;
        }

        .logout {
            background: #e74c3c;
        }

        .logout:hover {
            background: #c0392b;
        }

        hr {
            margin: 30px 0;
        }

    </style>
</head>

<body>

<div class="container">

    <h1>Welcome <%= username %></h1>

    <h2>Teacher Features</h2>

    <a href="/dashboard">Create Test</a>

    <a href="/results">View Student Results</a>

    <a href="/uploadMaterial.html">
        Upload Study Material
    </a>

    <a href="/tests">Manage Tests</a>

    <!-- ST3 FEATURES -->
    <a href="/upload-assignment">
        Upload Assignment
    </a>

    <a href="/assignments">
        View Assignments
    </a>

    <hr>

    <h2>Platform Services</h2>

    <a href="/profile">Profile Page</a>

    <a href="/chat.html">Chat System</a>

    <a href="/set-session">Create Session</a>

    <a href="/set-cookie">Set Cookie</a>

    <a href="/blocking">Blocking Example</a>

    <a href="/non-blocking">Non-Blocking Example</a>

    <hr>

    <a href="/" class="logout">Logout</a>

</div>

</body>
</html>