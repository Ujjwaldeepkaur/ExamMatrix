<!DOCTYPE html>
<html>
<head>
    <title>Manage Tests</title>

    <style>
        body {
            margin: 0;
            padding: 0;
            font-family: Arial;
            background: linear-gradient(to right, #36d1dc, #5b86e5);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .container {
            width: 900px;
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: 0px 0px 20px rgba(0,0,0,0.2);
            text-align: center;
        }

        h1 {
            color: #2c3e50;
            margin-bottom: 30px;
        }

        .test-box {
            background: #f8f9fa;
            border: 1px solid #ddd;
            border-radius: 12px;
            padding: 20px;
            margin-bottom: 20px;
            text-align: left;
        }

        h2 {
            color: #34495e;
            margin-bottom: 10px;
        }

        p {
            font-size: 16px;
            color: #555;
            margin: 8px 0;
        }

        .back-btn {
            text-decoration: none;
            background: #27ae60;
            color: white;
            padding: 12px 24px;
            border-radius: 8px;
            display: inline-block;
            margin-top: 20px;
        }

        .back-btn:hover {
            background: #1e8449;
        }
    </style>
</head>
<body>

<div class="container">

    <h1>Manage Created Tests</h1>

    <% tests.forEach(function(test) { %>

        <div class="test-box">

            <h2><%= test.testName %></h2>

            <p><b>Subject:</b> <%= test.subject %></p>

            <p><b>Question:</b> <%= test.question %></p>

            <p><b>Option 1:</b> <%= test.option1 %></p>
            <p><b>Option 2:</b> <%= test.option2 %></p>
            <p><b>Option 3:</b> <%= test.option3 %></p>
            <p><b>Option 4:</b> <%= test.option4 %></p>

            <p><b>Correct Answer:</b> <%= test.answer %></p>

        </div>

    <% }) %>

    <a href="/teacher-dashboard" class="back-btn">
        Back to Dashboard
    </a>

</div>

</body>
</html>